<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>{% block title %}Welcome!{% endblock %}</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
{% block stylesheets %}
{% endblock %}
<style>
table, th, td, caption {
  border: 1px solid black;
}
</style>

{% block javascripts %}
{% endblock %}
</head>
<body>
{% block body %}

<table>
<caption>All users</caption>
<thead>
<tr>
<th>Id</th>
<th>Username</th>
<th>Name</th>
<th>Email</th>
<th>Enable</th>
<th>Birthdate</th>
<th>Address</th>
<th>Action</th>
</tr>
</thead>
<tbody>
{% for user in all_users %}
<tr>
<td>{{user.id}}</td>
<td>{{user.username}}</td>
<td>{{user.name}}</td>
<td>{{user.email}}</td>
<td>{{user.enable == 1 ? 'Yes' : 'No'}}</td>
<td>{{user.birthdate|date("m/d/Y")}}</td>
<td>{{user.address}}</td>
<td><a href="/e04/delete/{{user.id}}">Delete</a></td>
</tr>
{% endfor %}	
</tbody>
</table>

<a href="/e04/create_form">Back to form</a>

{% endblock %}
</body>
</html>
