{% extends 'base.html.twig' %}

{% block title %}Table users ORM table{% endblock %}

{% block body %}
<style>
table, th, td, caption {
  border: 1px solid black;
}

    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">


<table>
<caption>All users from ORM table</caption>
<thead>
<tr>
	<td>ID</td>
	<td>Username</td>
	<td>Name</td>
</tr>
</thead>
<tbody>
{% for user in users %}
<tr>
<td>{{user.id}}</td>
<td>{{user.username}}</td>
<td>{{user.name}}</td>
</tr>
{% endfor %}	
</tbody>
</table>
</div>

{% endblock %}
